---
const education = [
  { title: "Maestría en Ingeniería de Software", place: "UPEC", period: "03-2026 - Presente" },
  { title: "Ingeniería en Ciencias de la Computación", place: "UPEC", period: "02-2025" },
  { title: "Bachillerato en Ventas e Información Turística", place: "U.E. Gonzalo Zaldumbide", period: "07-2018" },
];

const experience = [
  {
    role: "Técnico Docente",
    company: "UPEC",
    period: "abr. 2025 - presente",
    desc: "Desarrollo de módulos del portafolio institucional.",
    stack: "Oracle APEX, Oracle Database 19c",
  },
  {
    role: "Desarrollador",
    company: "UPEC",
    period: "sep. 2023 – feb. 2025",
    desc: "Aplicación web para automatizar el proceso de prácticas (generación y firma de documentos legales en PDF).",
    stack: "PHP (Laravel + Livewire), Linux, Apache2, MySQL",
  },
  {
    role: "Facilitador",
    company: "UPEC",
    period: "abr. 2024 – sep. 2024",
    desc: "Capacitación en herramientas informáticas y soporte técnico en Unidades Educativas del Cantón Tulcán.",
    stack: null,
  },
  {
    role: "Desarrollador",
    company: "FasTech",
    period: "feb. 2023 – presente",
    desc: "Desarrollo de Stocker: aplicación web de contabilidad e inventario para pequeños emprendedores.",
    stack: "React, Laravel + Inertia, Linux, Apache2, MySQL",
  },
];

const certs = [
  "Certificación En Ciberseguridad – Cisco (2026)",
  "Formación de Formadores – UPEC (2026)",
  "Oracle Apex Foundations – Oracle (2025)",
  "OCI 2025 Certified Foundations – Oracle (2025)",
  "Foundations of User Experience – Google (2025)",
  "Desarrollo de Aplicaciones Móviles – UCM (2023)",
];

const skills = ["Oracle APEX", "PL/SQL", "Laravel", "React", "Linux", "UI/UX", "RouterOS (Mikrotik)"];
---

<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Ariel Aguirre - Portfolio</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=VT323&display=swap" rel="stylesheet" />
  <script src="https://t.contentsquare.net/uxa/f5089c8198d00.js"></script>

  <style>
    @font-face {
      font-family: 'W95FA';
      src: local('MS Sans Serif'), local('Microsoft Sans Serif'), local('Tahoma');
      font-weight: normal;
    }

    :root {
      --win-bg: #008080;
      --win-silver: #c0c0c0;
      --win-dark: #808080;
      --win-white: #ffffff;
      --win-black: #000000;
      --win-title: #000080;
      --win-title-text: #ffffff;
      --win-highlight: #000080;
      --win-btn-face: #c0c0c0;
      --win-btn-highlight: #ffffff;
      --win-btn-shadow: #808080;
      --win-btn-dk-shadow: #000000;
      --font-sys: 'Tahoma', 'MS Sans Serif', 'Arial', sans-serif;
      --font-mono: 'VT323', 'Courier New', monospace;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background: var(--win-bg);
      font-family: var(--font-sys);
      font-size: 11px;
      color: var(--win-black);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      cursor: default;
      overflow-x: hidden;
    }

    /* ---- DESKTOP ICONS ---- */
    .desktop {
      flex: 1;
      padding: 16px;
      display: flex;
      flex-wrap: wrap;
      align-content: flex-start;
      gap: 8px;
      position: relative;
    }

    .desktop-icon {
      width: 72px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      padding: 4px;
      cursor: pointer;
      user-select: none;
      text-align: center;
    }
    .desktop-icon:hover .icon-label,
    .desktop-icon:focus .icon-label {
      background: var(--win-highlight);
      color: var(--win-title-text);
    }
    .desktop-icon .icon-img {
      width: 32px;
      height: 32px;
      image-rendering: pixelated;
    }
    .icon-label {
      font-size: 11px;
      color: var(--win-white);
      padding: 1px 2px;
      text-shadow: 1px 1px 0 rgba(0,0,0,0.7);
    }

    /* ---- WINDOW ---- */
    .window {
      position: absolute;
      background: var(--win-silver);
      border-top: 2px solid var(--win-btn-highlight);
      border-left: 2px solid var(--win-btn-highlight);
      border-right: 2px solid var(--win-btn-dk-shadow);
      border-bottom: 2px solid var(--win-btn-dk-shadow);
      box-shadow: inset 1px 1px 0 var(--win-btn-face), inset -1px -1px 0 var(--win-btn-shadow);
      display: none;
      flex-direction: column;
      z-index: 10;
      min-width: 320px;
      max-width: 95vw;
      max-height: 85vh;
    }
    .window.active { display: flex; z-index: 20; }
    .window.maximized {
      top: 0 !important;
      left: 0 !important;
      width: 100vw !important;
      max-width: 100vw !important;
      height: calc(100vh - 28px) !important;
      max-height: calc(100vh - 28px) !important;
    }

    .title-bar {
      background: linear-gradient(90deg, var(--win-title), #1084d0);
      color: var(--win-title-text);
      display: flex;
      align-items: center;
      padding: 2px 3px;
      gap: 4px;
      font-weight: bold;
      font-size: 11px;
      user-select: none;
      cursor: grab;
    }
    .title-bar .title-text { flex: 1; padding-left: 2px; }
    .title-bar-btn {
      width: 16px;
      height: 14px;
      background: var(--win-silver);
      border-top: 1px solid var(--win-btn-highlight);
      border-left: 1px solid var(--win-btn-highlight);
      border-right: 1px solid var(--win-btn-dk-shadow);
      border-bottom: 1px solid var(--win-btn-dk-shadow);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 9px;
      font-weight: bold;
      cursor: pointer;
      font-family: var(--font-sys);
      line-height: 1;
      padding: 0;
    }
    .title-bar-btn:active {
      border-top: 1px solid var(--win-btn-dk-shadow);
      border-left: 1px solid var(--win-btn-dk-shadow);
      border-right: 1px solid var(--win-btn-highlight);
      border-bottom: 1px solid var(--win-btn-highlight);
    }

    .menu-bar {
      display: flex;
      gap: 0;
      padding: 2px 0;
      border-bottom: 1px solid var(--win-btn-shadow);
    }
    .menu-item {
      padding: 2px 6px;
      cursor: pointer;
    }
    .menu-item:hover { background: var(--win-highlight); color: var(--win-title-text); }

    .window-body {
      flex: 1;
      overflow-y: auto;
      padding: 8px;
      background: var(--win-white);
      border-top: 1px solid var(--win-btn-shadow);
      border-left: 1px solid var(--win-btn-shadow);
      border-right: 1px solid var(--win-btn-highlight);
      border-bottom: 1px solid var(--win-btn-highlight);
      margin: 2px;
    }

    .status-bar {
      display: flex;
      border-top: 1px solid var(--win-btn-shadow);
      padding: 2px 4px;
      font-size: 11px;
      gap: 4px;
    }
    .status-section {
      border-top: 1px solid var(--win-btn-shadow);
      border-left: 1px solid var(--win-btn-shadow);
      border-right: 1px solid var(--win-btn-highlight);
      border-bottom: 1px solid var(--win-btn-highlight);
      padding: 1px 4px;
      flex: 1;
    }

    /* ---- CONTENT STYLING ---- */
    .section-title {
      font-family: var(--font-mono);
      font-size: 18px;
      font-weight: bold;
      border-bottom: 2px solid var(--win-dark);
      margin-bottom: 8px;
      padding-bottom: 4px;
    }

    .info-grid {
      display: grid;
      grid-template-columns: 120px 1fr;
      gap: 2px 8px;
      margin-bottom: 12px;
    }
    .info-grid dt { font-weight: bold; }
    .info-grid dd { margin: 0; }

    .exp-item {
      margin-bottom: 10px;
      padding: 6px;
      background: var(--win-silver);
      border-top: 1px solid var(--win-btn-highlight);
      border-left: 1px solid var(--win-btn-highlight);
      border-right: 1px solid var(--win-btn-dk-shadow);
      border-bottom: 1px solid var(--win-btn-dk-shadow);
    }
    .exp-header {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      flex-wrap: wrap;
      gap: 4px;
    }
    .exp-role { font-weight: bold; }
    .exp-period { font-style: italic; color: var(--win-dark); font-size: 10px; }
    .exp-company { color: var(--win-title); font-weight: bold; }
    .exp-stack {
      margin-top: 4px;
      font-family: var(--font-mono);
      font-size: 14px;
      color: var(--win-dark);
    }

    .cert-list, .skill-tags { list-style: none; padding: 0; }
    .cert-list li {
      padding: 2px 4px;
      border-bottom: 1px dotted var(--win-dark);
    }
    .cert-list li::before { content: "📄 "; }

    .skill-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
    }
    .skill-tag {
      background: var(--win-highlight);
      color: var(--win-title-text);
      padding: 2px 8px;
      font-size: 11px;
      font-weight: bold;
    }

    .edu-item {
      margin-bottom: 6px;
      padding: 4px 6px;
      border-left: 3px solid var(--win-title);
    }
    .edu-title { font-weight: bold; }
    .edu-meta { color: var(--win-dark); font-size: 10px; }

    /* ---- TASKBAR ---- */
    .taskbar {
      height: 28px;
      background: var(--win-silver);
      border-top: 2px solid var(--win-btn-highlight);
      display: flex;
      align-items: center;
      padding: 2px 4px;
      gap: 4px;
      z-index: 100;
    }
    .start-btn {
      height: 22px;
      padding: 1px 6px;
      display: flex;
      align-items: center;
      gap: 4px;
      font-weight: bold;
      font-size: 11px;
      font-family: var(--font-sys);
      cursor: pointer;
      background: var(--win-silver);
      border-top: 2px solid var(--win-btn-highlight);
      border-left: 2px solid var(--win-btn-highlight);
      border-right: 2px solid var(--win-btn-dk-shadow);
      border-bottom: 2px solid var(--win-btn-dk-shadow);
    }
    .start-btn:active {
      border-top: 2px solid var(--win-btn-dk-shadow);
      border-left: 2px solid var(--win-btn-dk-shadow);
      border-right: 2px solid var(--win-btn-highlight);
      border-bottom: 2px solid var(--win-btn-highlight);
    }
    .start-logo { font-size: 14px; }

    .taskbar-windows { display: flex; flex: 1; gap: 2px; overflow: hidden; }
    .taskbar-win-btn {
      height: 22px;
      min-width: 100px;
      max-width: 160px;
      padding: 1px 6px;
      font-size: 11px;
      font-family: var(--font-sys);
      text-align: left;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      cursor: pointer;
      background: var(--win-silver);
      border-top: 2px solid var(--win-btn-highlight);
      border-left: 2px solid var(--win-btn-highlight);
      border-right: 2px solid var(--win-btn-dk-shadow);
      border-bottom: 2px solid var(--win-btn-dk-shadow);
    }
    .taskbar-win-btn.active-btn {
      border-top: 2px solid var(--win-btn-dk-shadow);
      border-left: 2px solid var(--win-btn-dk-shadow);
      border-right: 2px solid var(--win-btn-highlight);
      border-bottom: 2px solid var(--win-btn-highlight);
      background: #b0b0b0;
    }

    .taskbar-clock {
      border-top: 1px solid var(--win-btn-shadow);
      border-left: 1px solid var(--win-btn-shadow);
      border-right: 1px solid var(--win-btn-highlight);
      border-bottom: 1px solid var(--win-btn-highlight);
      padding: 2px 8px;
      font-size: 11px;
      min-width: 56px;
      text-align: center;
    }

    /* ---- PIXEL ART ICONS (SVG inline) ---- */
    .px-icon {
      width: 32px;
      height: 32px;
    }

    /* ---- ABOUT WINDOW LAYOUT ---- */
    .about-header {
      text-align: center;
      margin-bottom: 12px;
    }
    .about-name {
      font-family: var(--font-mono);
      font-size: 28px;
      font-weight: bold;
      color: var(--win-title);
    }
    .about-tagline {
      font-size: 12px;
      color: var(--win-dark);
      margin-top: 2px;
    }
    .about-contact {
      display: flex;
      flex-wrap: wrap;
      gap: 6px 16px;
      justify-content: center;
      margin-top: 6px;
      font-size: 11px;
    }

    /* ---- BSOD EASTER EGG ---- */
    .bsod-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: #0000aa;
      color: #ffffff;
      font-family: var(--font-mono);
      font-size: 20px;
      padding: 40px;
      z-index: 9999;
      cursor: pointer;
      line-height: 1.6;
    }
    .bsod-overlay.show { display: block; }
    .bsod-title {
      background: var(--win-dark);
      color: #0000aa;
      display: inline-block;
      padding: 0 8px;
      background: #aaaaaa;
      margin-bottom: 24px;
    }

    /* Responsive */
    @media (max-width: 640px) {
      .window { min-width: 95vw; }
      .window.active:not(.maximized) {
        left: 2vw !important;
        width: 96vw !important;
      }
    }
  </style>
</head>
<body>

  <!-- Desktop Icons -->
  <div class="desktop">
    <div class="desktop-icon" data-win="about" tabindex="0">
      <svg class="px-icon" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="4" y="2" width="24" height="20" fill="#c0c0c0" stroke="#000" stroke-width="1"/>
        <rect x="6" y="4" width="20" height="14" fill="#000080"/>
        <rect x="10" y="22" width="12" height="3" fill="#c0c0c0" stroke="#000" stroke-width="1"/>
        <rect x="8" y="25" width="16" height="2" fill="#808080"/>
        <text x="16" y="14" text-anchor="middle" fill="#fff" font-size="7" font-family="monospace">AA</text>
      </svg>
      <span class="icon-label">Sobre Mí</span>
    </div>

    <div class="desktop-icon" data-win="exp" tabindex="0">
      <svg class="px-icon" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="3" y="6" width="26" height="20" rx="1" fill="#808040" stroke="#000" stroke-width="1"/>
        <rect x="10" y="3" width="12" height="5" rx="1" fill="#808040" stroke="#000" stroke-width="1"/>
        <rect x="5" y="14" width="22" height="1" fill="#c0c080"/>
      </svg>
      <span class="icon-label">Experiencia</span>
    </div>

    <div class="desktop-icon" data-win="edu" tabindex="0">
      <svg class="px-icon" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <polygon points="16,4 2,12 16,20 30,12" fill="#000080"/>
        <rect x="6" y="14" width="20" height="10" fill="#c0c0c0" stroke="#000080" stroke-width="1"/>
        <line x1="16" y1="20" x2="16" y2="28" stroke="#808000" stroke-width="2"/>
        <circle cx="16" cy="28" r="2" fill="#808000"/>
      </svg>
      <span class="icon-label">Educación</span>
    </div>

    <div class="desktop-icon" data-win="certs" tabindex="0">
      <svg class="px-icon" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="4" y="2" width="24" height="28" fill="#ffffcc" stroke="#000" stroke-width="1"/>
        <rect x="7" y="5" width="14" height="2" fill="#808080"/>
        <rect x="7" y="9" width="18" height="1" fill="#c0c0c0"/>
        <rect x="7" y="12" width="18" height="1" fill="#c0c0c0"/>
        <rect x="7" y="15" width="18" height="1" fill="#c0c0c0"/>
        <rect x="7" y="18" width="12" height="1" fill="#c0c0c0"/>
        <circle cx="22" cy="24" r="4" fill="#c0a000" stroke="#806000" stroke-width="1"/>
        <text x="22" y="26" text-anchor="middle" fill="#fff" font-size="5" font-family="monospace">OK</text>
      </svg>
      <span class="icon-label">Certificaciones</span>
    </div>

    <div class="desktop-icon" data-win="skills" tabindex="0">
      <svg class="px-icon" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="2" y="8" width="12" height="20" rx="1" fill="#c0c0c0" stroke="#000" stroke-width="1"/>
        <rect x="4" y="10" width="8" height="4" fill="#000080"/>
        <rect x="18" y="4" width="12" height="16" rx="1" fill="#c0c0c0" stroke="#000" stroke-width="1"/>
        <rect x="20" y="6" width="8" height="4" fill="#008080"/>
        <line x1="14" y1="16" x2="18" y2="12" stroke="#808080" stroke-width="1"/>
      </svg>
      <span class="icon-label">Habilidades</span>
    </div>

    <!-- WINDOWS -->
    <!-- About -->
    <div class="window" id="win-about" style="top:30px;left:40px;width:520px;">
      <div class="title-bar">
        <span class="title-text">Sobre Mí - Ariel Aguirre</span>
        <button class="title-bar-btn win-min" aria-label="Minimizar">_</button>
        <button class="title-bar-btn win-max" aria-label="Maximizar">□</button>
        <button class="title-bar-btn win-close" aria-label="Cerrar">×</button>
      </div>
      <div class="menu-bar">
        <span class="menu-item">Archivo</span>
        <span class="menu-item">Editar</span>
        <span class="menu-item">Ayuda</span>
      </div>
      <div class="window-body">
        <div class="about-header">
          <div class="about-name">Ariel Aguirre</div>
          <div class="about-tagline">Desarrollador de Software &bull; Tulcán, Ecuador</div>
          <div class="about-contact">
            <span>ariel.aguirre@upec.edu.ec</span>
            <span>0960 759 518</span>
            <a href="https://ariel.selfhostedec.org" target="_blank" rel="noopener">ariel.selfhostedec.org</a>
          </div>
        </div>
        <dl class="info-grid">
          <dt>C.C:</dt><dd>1050363736</dd>
          <dt>Estado civil:</dt><dd>Soltero</dd>
          <dt>Nacionalidad:</dt><dd>Ecuatoriana</dd>
          <dt>Nacimiento:</dt><dd>04/02/2001</dd>
        </dl>
        <p class="section-title">Intereses</p>
        <p style="margin-top:4px;">Pesca, Montañismo</p>
      </div>
      <div class="status-bar">
        <div class="status-section">Listo</div>
      </div>
    </div>

    <!-- Experiencia -->
    <div class="window" id="win-exp" style="top:60px;left:80px;width:560px;">
      <div class="title-bar">
        <span class="title-text">Experiencia Laboral</span>
        <button class="title-bar-btn win-min">_</button>
        <button class="title-bar-btn win-max">□</button>
        <button class="title-bar-btn win-close">×</button>
      </div>
      <div class="menu-bar">
        <span class="menu-item">Archivo</span>
        <span class="menu-item">Ver</span>
      </div>
      <div class="window-body">
        <p class="section-title">Experiencia</p>
        {experience.map((e) => (
          <div class="exp-item">
            <div class="exp-header">
              <span class="exp-role">{e.role}</span>
              <span class="exp-period">{e.period}</span>
            </div>
            <div class="exp-company">{e.company}</div>
            <p style="margin-top:4px;">{e.desc}</p>
            {e.stack && <div class="exp-stack">Stack: {e.stack}</div>}
          </div>
        ))}
      </div>
      <div class="status-bar">
        <div class="status-section">{experience.length} elementos</div>
      </div>
    </div>

    <!-- Educación -->
    <div class="window" id="win-edu" style="top:50px;left:120px;width:440px;">
      <div class="title-bar">
        <span class="title-text">Educación</span>
        <button class="title-bar-btn win-min">_</button>
        <button class="title-bar-btn win-max">□</button>
        <button class="title-bar-btn win-close">×</button>
      </div>
      <div class="window-body">
        <p class="section-title">Formación Académica</p>
        {education.map((e) => (
          <div class="edu-item">
            <div class="edu-title">{e.title}</div>
            <div class="edu-meta">{e.place} &mdash; {e.period}</div>
          </div>
        ))}
      </div>
      <div class="status-bar">
        <div class="status-section">Listo</div>
      </div>
    </div>

    <!-- Certificaciones -->
    <div class="window" id="win-certs" style="top:80px;left:160px;width:480px;">
      <div class="title-bar">
        <span class="title-text">Certificaciones</span>
        <button class="title-bar-btn win-min">_</button>
        <button class="title-bar-btn win-max">□</button>
        <button class="title-bar-btn win-close">×</button>
      </div>
      <div class="window-body">
        <p class="section-title">Cursos y Certificaciones</p>
        <ul class="cert-list">
          {certs.map((c) => <li>{c}</li>)}
        </ul>
      </div>
      <div class="status-bar">
        <div class="status-section">{certs.length} certificaciones</div>
      </div>
    </div>

    <!-- Habilidades -->
    <div class="window" id="win-skills" style="top:100px;left:200px;width:400px;">
      <div class="title-bar">
        <span class="title-text">Habilidades</span>
        <button class="title-bar-btn win-min">_</button>
        <button class="title-bar-btn win-max">□</button>
        <button class="title-bar-btn win-close">×</button>
      </div>
      <div class="window-body">
        <p class="section-title">Stack Técnico</p>
        <div class="skill-tags">
          {skills.map((s) => <span class="skill-tag">{s}</span>)}
        </div>
      </div>
      <div class="status-bar">
        <div class="status-section">{skills.length} habilidades</div>
      </div>
    </div>
  </div>

  <!-- BSOD Easter Egg -->
  <div class="bsod-overlay" id="bsod">
    <span class="bsod-title">&nbsp;Windows&nbsp;</span>
    <br/><br/>
