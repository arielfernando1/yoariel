  <!-- Taskbar -->
  <div class="taskbar">
    <button class="start-btn" id="startBtn">
      <span class="start-logo">&#9632;</span> Inicio
    </button>
    <div class="taskbar-windows" id="taskbarWindows"></div>
    <div class="taskbar-clock" id="clock"></div>
  </div>

  <script>
    // Window management
    const wins = document.querySelectorAll('.window');
    const taskbarArea = document.getElementById('taskbarWindows');
    const icons = document.querySelectorAll('.desktop-icon');
    let zCounter = 20;
    let activeWin = null;

    function updateClock() {
      const n = new Date();
      document.getElementById('clock').textContent =
        n.toLocaleTimeString('es-EC', { hour: '2-digit', minute: '2-digit' });
    }
    updateClock();
    setInterval(updateClock, 30000);

    function bringToFront(win) {
      zCounter++;
      win.style.zIndex = zCounter;
      activeWin = win;
      // update taskbar buttons
      taskbarArea.querySelectorAll('.taskbar-win-btn').forEach(b => {
        b.classList.toggle('active-btn', b.dataset.win === win.id);
      });
    }

    function openWindow(id) {
      const win = document.getElementById('win-' + id);
      if (!win) return;
      win.classList.add('active');
      bringToFront(win);
      ensureTaskbarBtn(win);
    }

    function closeWindow(win) {
      win.classList.remove('active', 'maximized');
      const btn = taskbarArea.querySelector(`[data-win="${win.id}"]`);
      if (btn) btn.remove();
    }

    function ensureTaskbarBtn(win) {
      if (taskbarArea.querySelector(`[data-win="${win.id}"]`)) return;
      const btn = document.createElement('button');
      btn.className = 'taskbar-win-btn active-btn';
      btn.dataset.win = win.id;
      btn.textContent = win.querySelector('.title-text').textContent;
      btn.addEventListener('click', () => {
        if (win.classList.contains('active') && activeWin === win) {
          win.classList.remove('active');
        } else {
          win.classList.add('active');
          bringToFront(win);
        }
      });
      taskbarArea.appendChild(btn);
    }

    // Desktop icon double-click
    icons.forEach(icon => {
      icon.addEventListener('dblclick', () => openWindow(icon.dataset.win));
      icon.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') openWindow(icon.dataset.win);
      });
    });

    // Window buttons
    wins.forEach(win => {
      win.addEventListener('mousedown', () => bringToFront(win));

      win.querySelector('.win-close')?.addEventListener('click', () => closeWindow(win));
      win.querySelector('.win-min')?.addEventListener('click', () => {
        win.classList.remove('active');
      });
      win.querySelector('.win-max')?.addEventListener('click', () => {
        win.classList.toggle('maximized');
      });

      // Dragging
      const tb = win.querySelector('.title-bar');
      let dragging = false, ox = 0, oy = 0;
      tb.addEventListener('mousedown', (e) => {
        if (e.target.classList.contains('title-bar-btn')) return;
        if (win.classList.contains('maximized')) return;
        dragging = true;
        ox = e.clientX - win.offsetLeft;
        oy = e.clientY - win.offsetTop;
        bringToFront(win);
      });
      document.addEventListener('mousemove', (e) => {
        if (!dragging) return;
        win.style.left = (e.clientX - ox) + 'px';
        win.style.top = (e.clientY - oy) + 'px';
      });
      document.addEventListener('mouseup', () => { dragging = false; });
    });

    // Start button -> BSOD easter egg
    let clickCount = 0;
    document.getElementById('startBtn').addEventListener('click', () => {
      clickCount++;
      if (clickCount >= 3) {
        document.getElementById('bsod').classList.add('show');
        clickCount = 0;
      }
    });
    document.getElementById('bsod').addEventListener('click', () => {
      document.getElementById('bsod').classList.remove('show');
    });
    document.addEventListener('keydown', () => {
      document.getElementById('bsod').classList.remove('show');
    });
  </script>
</body>
</html>
